# Copy this file to backend/.env and adjust as needed.
# The app works out of the box with SQLite and no .env file at all.

DATABASE_URL=sqlite:///./job_scheduler.db
# For Postgres in production:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/jobscheduler

JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_HEARTBEAT_INTERVAL_SECONDS=5.0
WORKER_HEARTBEAT_TIMEOUT_SECONDS=30
SCHEDULER_POLL_INTERVAL_SECONDS=1.0

DEFAULT_MAX_RETRIES=3
DEFAULT_RETRY_STRATEGY=exponential
DEFAULT_RETRY_BASE_DELAY_SECONDS=5
